{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "avatar": { "type": "string", "description": "URL to user's avatar image" },
        "bio": { "type": "string", "description": "User's short biography" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["name", "email", "createdAt"]
    },
    "Video": {
      "title": "Video",
      "description": "Video metadata and content",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Video title" },
        "description": { "type": "string", "description": "Video description" },
        "videoUrl": { "type": "string", "description": "URL to the video file in Firebase Storage" },
        "thumbnailUrl": { "type": "string", "description": "URL to the thumbnail image in Firebase Storage" },
        "userId": { "type": "string", "description": "ID of the user who uploaded the video" },
        "userName": { "type": "string", "description": "Name of the uploader" },
        "userAvatar": { "type": "string", "description": "Avatar of the uploader" },
        "views": { "type": "integer", "description": "Number of views" },
        "likes": { "type": "integer", "description": "Number of likes" },
        "dislikes": { "type": "integer", "description": "Number of dislikes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload timestamp" },
        "category": { "type": "string", "description": "Video category" }
      },
      "required": ["title", "videoUrl", "thumbnailUrl", "userId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on a video",
      "type": "object",
      "properties": {
        "videoId": { "type": "string", "description": "ID of the video" },
        "userId": { "type": "string", "description": "ID of the commenter" },
        "userName": { "type": "string", "description": "Name of the commenter" },
        "userAvatar": { "type": "string", "description": "Avatar of the commenter" },
        "text": { "type": "string", "description": "Comment text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Comment timestamp" }
      },
      "required": ["videoId", "userId", "text", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription relationship",
      "type": "object",
      "properties": {
        "followerId": { "type": "string", "description": "ID of the user who is following" },
        "followingId": { "type": "string", "description": "ID of the user being followed" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Subscription timestamp" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user receiving the notification" },
        "type": { "type": "string", "description": "Type of notification (e.g., new_video, new_comment)" },
        "message": { "type": "string", "description": "Notification message" },
        "videoId": { "type": "string", "description": "ID of the related video" },
        "isRead": { "type": "boolean", "description": "Whether the notification has been read" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Notification timestamp" }
      },
      "required": ["userId", "type", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Video metadata"
    },
    "/videos/{videoId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a video"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "User subscriptions"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
